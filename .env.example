# ============================================================================
# .env.example  —  copy to `.env` and fill in.  NEVER commit the real .env.
# ============================================================================

# --- Wallet / signing -------------------------------------------------------
# The private key that SIGNS orders. For an email/Magic or browser-wallet
# Polymarket account this is the key of the *signing* EOA, which is NOT the
# address holding your funds (that is the funder/proxy below).
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# The address that actually HOLDS your USDC on Polymarket (the "funder").
# - EOA / MetaMask users:        this equals your own wallet address.
# - Email (Magic) / browser:     this is your Polymarket proxy/deposit address,
#                                 shown on polymarket.com under Deposit.
POLYMARKET_FUNDER=0xYOUR_FUNDER_ADDRESS_HERE

# How Polymarket should verify your signatures:
#   0 = EOA (MetaMask / hardware / raw private key)
#   1 = email / Magic wallet (proxy)
#   2 = browser-extension wallet (Gnosis Safe proxy)
POLYMARKET_SIGNATURE_TYPE=1

# --- Optional CLOB API credentials (L2 / HMAC) ------------------------------
# Leave blank to auto-derive them from the private key at startup
# (client.create_or_derive_api_creds). Fill them only if you pre-generated keys.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# --- Builder attribution (optional) -----------------------------------------
# Builder/affiliate key for the Polymarket Builder program (order attribution).
# Optional: trading works without it. Wired into exchange.py if present.
POLYMARKET_BUILDER_API_KEY=

# --- Endpoints (override only if you know why) ------------------------------
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@trade
BINANCE_REST_URL=https://api.binance.com/api/v3/ticker/price
CHAIN_ID=137
